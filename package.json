{
  "name": "@mdaemon/folder-tree",
  "version": "1.0.1",
  "description": "A zero-dependency TypeScript tree view component — drop-in jstree replacement, no jQuery required",
  "homepage": "https://github.com/mdaemon-technologies/folder-tree",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdaemon-technologies/folder-tree.git"
  },
  "bugs": {
    "url": "https://github.com/mdaemon-technologies/folder-tree/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "style": "dist/styles.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "default": "./dist/styles.css"
    },
    "./styles.css": {
      "types": "./dist/styles.d.ts",
      "default": "./dist/styles.css"
    },
    "./dist/styles.css": "./dist/styles.css",
    "./umd": "./dist/MDFolderTree.umd.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --mode production && vite build --mode umd",
    "build:dev": "vite build --mode development",
    "build:umd": "vite build --mode umd",
    "build:all": "npm run build",
    "dev": "vite build --watch --mode development",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "demo": "vite demo"
  },
  "keywords": [
    "tree",
    "treeview",
    "folder-tree",
    "jstree",
    "jstree-replacement",
    "zero-dependency",
    "typescript",
    "checkbox-tree"
  ],
  "author": {
    "name": "MDaemon Technologies, Ltd.",
    "email": "jonathan.ehman@mdaemon.com",
    "url": "https://www.mdaemon.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "dts-bundle-generator": "^9.5.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^5.0.1"
  }
}
